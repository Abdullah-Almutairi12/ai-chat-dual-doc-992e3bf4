# Public site URL (Vercel production domain — used for OAuth redirects & Tap webhooks)
APP_ORIGIN=https://your-project.vercel.app

# ── Supabase (client — embedded at build via VITE_ prefix) ─────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# ── Supabase (server — Vercel Production env, never exposed to browser) ─────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=

# ── Tap Payments (server-only) ─────────────────────────────────────────────
TAP_SECRET_KEY=
TAP_WEBHOOK_URL=

# ── Email & cron (server-only) ─────────────────────────────────────────────
RESEND_API_KEY=
CRON_SECRET=

# ── Vision AI (server-only — PDF → Word/PPT with OCR + layout) ─────────────
# Set at least one key on the Vercel project linked to pdfquanta.online (o8pv).
# Optional: custom cloud endpoint (OpenRouter, Azure, self-hosted OpenAI-compatible).
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-5
VISION_AI_PROVIDER=openai

# Build target: NITRO_PRESET=vercel (set in vercel.json + npm run build)
