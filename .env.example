# Public site URL (Vercel production domain — used for OAuth redirects & Tap webhooks)
APP_ORIGIN=https://your-project.vercel.app

# ── Supabase (Vercel / production) ───────────────────────────────────────────
# Required for auth + database. Use either naming style:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
# Alternative names also supported:
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   (server-only — billing, webhooks, admin)

# Optional VITE_ duplicates for local dev (client bundle):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Tap Payments ─────────────────────────────────────────────────────────────
TAP_SECRET_KEY=
TAP_WEBHOOK_URL=

# ── Email & cron ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
CRON_SECRET=
